#!/bin/bash


run_cmd() {
    clear
    "$@"
}

while true; do
    clear
    echo "==== Terminal Fun Menu ===="
    echo "1) cmatrix"
    echo "2) pipes.sh"
    echo "3) tty-clock"
    echo "4) rain"
    echo "5) syscat"
    echo "6) donut"
    echo "7) Exit"
    read -p "Choice: " c

    case $c in
        1)
            run_cmd unimatrix   # runs cmatrix -u 10
            ;;
        2)
            run_cmd pipes       # runs pipes.sh
            ;;
        3)
            run_cmd tty-clock -c
            ;;
        4)
            run_cmd rain
            ;;
        5)
            run_cmd syscat
            ;;
        6)
            run_cmd donut
            ;;
        7)
            exit
            ;;
        *)
            echo "Invalid"
            read -p "Press enter..."
            ;;
    esac
done
